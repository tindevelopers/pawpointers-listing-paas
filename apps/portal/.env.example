# Portal env template

# Branding / platform
NEXT_PUBLIC_PLATFORM_NAME=Your Platform

# API endpoints
NEXT_PUBLIC_API_URL=https://api.example.com

# Admin dashboard URL (member redirect after signup)
NEXT_PUBLIC_ADMIN_URL=https://admin.example.com

# Supabase (optional but required for auth/reviews/chat if enabled)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chat / AI (optional)
# Option A: OpenAI / gateway
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Option B: Abacus custom chatbot (Predictions API / getChatResponse, e.g. ASK JOEY)
# AI_CHAT_PROVIDER=abacus
# ABACUS_DEPLOYMENT_TOKEN=<from Abacus Predictions API>
# ABACUS_DEPLOYMENT_ID=<from Abacus Predictions API>
# ABACUS_API_BASE_URL=https://apps.abacus.ai  # optional; default apps.abacus.ai

# Routing and taxonomy
ROUTING_STRATEGY=industry # or geographic
TAXONOMY_CONFIG=industry  # or location | hybrid
NEXT_PUBLIC_COUNTRY_SUBDOMAINS=us,uk,ca

# Images / CDN
NEXT_PUBLIC_CDN_URL=https://cdn.example.com
NEXT_PUBLIC_IMAGE_HOSTS=images.example.com,another-cdn.example.com

# Maps - at least one required for location display on listings and search
# Option A: Google Maps Embed API (enable "Maps Embed API" in Google Cloud)
# https://developers.google.com/maps/documentation/embed/get-started
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=
# Option B: Mapbox - https://www.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Reviews / optional services
# Add service-specific keys here as needed
